# ===========================================
# AegisDesk - Git Ignore Rules
# ===========================================

# Environment files (CRITICAL - never commit)
.env
.env.local
.env.development
.env.production
.env.*.local
.env.test
.env.staging
aegisdesk/.env
aegisdesk/.env.local
aegisdesk/.env.development
aegisdesk/.env.production
aegisdesk/.env.staging
aegisdesk/.env.test

# BUT keep .env.example for users to copy
!.env.example
aegisdesk/.env.example

# Sensitive configuration files
*.pem
*.key
*.crt
*.p12
*.pfx
credentials.json
service-account.json
*.secret
*.credentials

# AWS / Cloud credentials
.aws/
credentials
*.awscredentials

# Docker secrets (if used)
docker-compose.override.yml
.docker/

# Sync queue (local data)
.sync-queue/
aegisdesk/.sync-queue/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Build outputs
dist/
build/
*.tsbuildinfo
.next/
out/

# Local data (PowerSync local database)
aegisdesk/.local-data/

# Dependencies
node_modules/
aegisdesk/node_modules/

# Package lock files (optional - can cause conflicts)
# Uncomment if you want to include package-lock.json
# package-lock.json
# aegisdesk/package-lock.json

# Test coverage
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
.cache/

# SQL dumps (may contain sensitive data)
*.sql.bak
*.sql.dump

# Storybook
storybook-static/

# Turborepo
.turbo/

# Vercel
.vercel

# TypeScript
*.tsbuildinfo

# Git directory
!.gitignore


